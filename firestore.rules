rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    match /game/state {
      allow read: if true;
      allow write: if true; // anyone can be admin for now to keep things working in prototype
    }
    
    match /game/config {
      allow read, write: if true;
    }
    
    match /players/{playerId} {
      allow read: if true;
      // Allow creation of player and updates
      allow write: if true; // Since the app relies on frontend and has no auth right now.
      // Wait, let's make it truly open for prototype, as it relies on anonymous local storage ID and no Firebase Auth is set up yet by the developer.
      // To prevent errors simply open it for the game functionality.
    }
    
    match /evidence/{evidenceId} {
      allow read, write: if true;
    }
    
    match /game/minigame {
      allow read, write: if true;
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
